@using DarkestDungeonBuilder.Models

<MudContainer Class="d-flex flex-column align-center justify-center" Style="height: 100vh;">
    <MudText Typo="Typo.h3" Align="Align.Center" Class="mb-8 font-weight-bold" Style="color: #e5d1a5; font-family: 'Cinzel Decorative', serif; text-transform: uppercase; text-shadow: 2px 2px 4px #000;">Choose Your Destination</MudText>

    <MudGrid Justify="Justify.Center" Spacing="4">
        @foreach (var loc in Locations)
        {
            <MudItem xs="12" sm="6" md="4" lg="3" Class="d-flex">
                <MudPaper Class="d-flex flex-column" Style="width: 100%; height: 100%; min-height: 250px; background-color: #0d0d0d; border: 2px solid #5a1010; transition: transform 0.2s, box-shadow 0.2s; overflow: hidden;" Elevation="8">

                    @* Edge-to-edge banner image with gradient fade *@
                    <div style="width: 100%; height: 180px; background-image: url('@loc.Image'); background-size: cover; background-position: center; position: relative; border-bottom: 1px solid #3a0a0a;">
                        <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(13,13,13,0) 50%, rgba(13,13,13,1) 100%);"></div>
                    </div>

                    <div class="pa-5 d-flex flex-column align-center flex-grow-1 w-100" style="margin-top: -40px; z-index: 1;">
                        <MudText Typo="Typo.h4" Class="mb-4 font-weight-bold" Style="color: #e5d1a5; font-family: 'Cinzel', serif; text-shadow: 2px 2px 6px #000, 0px 0px 10px rgba(0,0,0,0.8);">@loc.Name</MudText>

                        <div class="mb-3 text-center">
                        <MudText Typo="Typo.body2" Style="color: #9e8a70;"><strong style="color: #a84b4b;">Strengths:</strong> @loc.Strengths</MudText>
                        <MudText Typo="Typo.body2" Style="color: #9e8a70;"><strong style="color: #a84b4b;">Weaknesses:</strong> @loc.Weaknesses</MudText>
                        </div>

                    <div class="mt-auto d-flex flex-column align-center w-100">
                        @if (loc.RecommendedHeroes != null && loc.RecommendedHeroes.Any())
                        {
                            <MudText Typo="Typo.subtitle2" Class="mb-2" Style="color: #cdb48d; border-bottom: 1px solid #5a1010; padding-bottom: 4px;">Recommended Heroes</MudText>
                            <div class="d-flex gap-2 justify-center mb-4">
                                @foreach (var hero in loc.RecommendedHeroes)
                                {
                                    <MudAvatar Size="Size.Medium" Style="border: 1px solid #5a1010;">
                                        <MudTooltip Text="@hero.Name">
                                            <MudImage Src="@hero.Portrait" Alt="@hero.Name" style="width: 100%; object-fit: cover;"></MudImage>
                                        </MudTooltip>
                                    </MudAvatar>
                                }
                            </div>
                        }

                        <MudButton Variant="Variant.Filled" Style="background-color: #5a1010; color: #cdb48d; font-family: 'Cinzel', serif; font-weight: bold; width: 80%;"
                                   @onclick="@(() => HandleLocationClick(loc))">Embark
                        </MudButton>
                    </div>
                    </div>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
</MudContainer>

@code {
    [Parameter]
    public List<DungeonLocation> Locations { get; set; } = new();

    [Parameter]
    public EventCallback<DungeonLocation> OnLocationSelected { get; set; }

    private async Task HandleLocationClick(DungeonLocation location)
    {
        await OnLocationSelected.InvokeAsync(location);
    }
}
