@using DarkestDungeonBuilder.Models

<MudContainer Class="d-flex flex-column align-center justify-center dd-fullscreen">
    <MudText Typo="Typo.h3" Align="Align.Center" Class="mb-8 font-weight-bold dd-destination-title">Choose Your Destination</MudText>

    <MudGrid Justify="Justify.Center" Spacing="4">
        @foreach (var loc in Locations)
        {
            <MudItem xs="12" sm="6" md="4" lg="3" Class="d-flex">
                <MudPaper Class="d-flex flex-column dd-location-card" Elevation="8">

                    @* Edge-to-edge banner image with gradient fade *@
                    <div class="dd-location-banner" style="@($"--dd-location-image: url('{loc.Image}');")">
                        <div class="dd-location-banner-overlay"></div>
                    </div>

                    <div class="pa-5 d-flex flex-column align-center flex-grow-1 w-100 dd-location-content">
                        <MudText Typo="Typo.h4" Class="mb-4 font-weight-bold dd-location-name">@loc.Name</MudText>

                        <div class="mb-3 text-center">
                            <MudText Typo="Typo.body2" Class="dd-location-body"><span class="dd-location-label">Strengths:</span> @loc.Strengths</MudText>
                            <MudText Typo="Typo.body2" Class="dd-location-body"><span class="dd-location-label">Weaknesses:</span> @loc.Weaknesses</MudText>
                        </div>

                        <div class="mt-auto d-flex flex-column align-center w-100">
                            @if (loc.RecommendedHeroes != null && loc.RecommendedHeroes.Any())
                            {
                                <MudText Typo="Typo.subtitle2" Class="mb-2 dd-recommended-header">Recommended Heroes</MudText>
                                <div class="d-flex gap-2 justify-center mb-4">
                                    @foreach (var hero in loc.RecommendedHeroes)
                                    {
                                        <MudAvatar Size="Size.Medium" Class="dd-location-avatar">
                                            <MudTooltip Text="@hero.Name">
                                                <MudImage Src="@hero.Portrait" Alt="@hero.Name" Class="dd-avatar-image-cover"></MudImage>
                                            </MudTooltip>
                                        </MudAvatar>
                                    }
                                </div>
                            }

                            <MudButton Variant="Variant.Filled" Class="dd-btn-primary dd-embark-button"
                                       @onclick="@(() => HandleLocationClick(loc))">Embark
                            </MudButton>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
</MudContainer>

@code {
    [Parameter]
    public List<DungeonLocation> Locations { get; set; } = new();

    [Parameter]
    public EventCallback<DungeonLocation> OnLocationSelected { get; set; }

    private async Task HandleLocationClick(DungeonLocation location)
    {
        await OnLocationSelected.InvokeAsync(location);
    }
}
