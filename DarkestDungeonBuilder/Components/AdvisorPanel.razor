@using DarkestDungeonBuilder.Models
@using DarkestDungeonBuilder.Services

<MudItem xs="12" md="3">
    <MudPaper Class="pa-4 dd-advisor-panel">
        <MudText Typo="Typo.h5" Class="mb-4 font-weight-bold dd-advisor-title">Advisor</MudText>

        <SynergyChart CurrentTeam="CurrentTeam" CurrentLocation="CurrentLocation" />

        <MudText Typo="Typo.h6" Class="mb-2 font-weight-bold dd-text-heading">Warnings and tips:</MudText>

        @if (!CurrentTeam.Slots.Values.Any(h => h != null))
        {
            <MudText Typo="Typo.body2" Class="dd-text-muted-italic">Add heroes to start the analysis.</MudText>
        }
        else if (!Analysis.HasAnyMessages)
        {
            <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Class="dd-success-alert">
                Looks good!
            </MudAlert>
        }
        else
        {
            @if (Analysis.CriticalIssues.Count > 0)
            {
                <MudText Typo="Typo.subtitle2" Class="mb-2 dd-advisor-section-title">Critical issues</MudText>
                <div class="d-flex flex-column gap-2 mb-3">
                    @foreach (var warning in Analysis.CriticalIssues)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true" Icon="@Icons.Material.Filled.WarningAmber" Class="dd-warning-alert">
                            @warning
                        </MudAlert>
                    }
                </div>
            }

            @if (Analysis.Suggestions.Count > 0)
            {
                <MudText Typo="Typo.subtitle2" Class="mb-2 dd-advisor-section-title">Suggestions</MudText>
                <div class="d-flex flex-column gap-2">
                    @foreach (var tip in Analysis.Suggestions)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true" Icon="@Icons.Material.Filled.TipsAndUpdates" Class="dd-tip-alert">
                            @tip
                        </MudAlert>
                    }
                </div>
            }
        }
    </MudPaper>
</MudItem>

@code {
    [Parameter, EditorRequired]
    public AdvisorAnalysis Analysis { get; set; } = new();

    [Parameter, EditorRequired]
    public Team CurrentTeam { get; set; } = null!;

    [Parameter]
    public DungeonLocation? CurrentLocation { get; set; }
}
