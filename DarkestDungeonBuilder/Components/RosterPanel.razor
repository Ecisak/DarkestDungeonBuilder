@using DarkestDungeonBuilder.Models

            <MudItem xs="12" md="3" Class="dd-roster-panel-column" ondragover="event.preventDefault();" @ondrop="@(() => OnDropToRoster.InvokeAsync())">
                <MudText Typo="Typo.h5" Class="font-weight-bold dd-title-inline dd-roster-location-title">@SelectedLocation.Name</MudText>
                <div class="dd-roster-actions">
                    <MudButton Variant="Variant.Filled" Size="Size.Small" Class="dd-btn-primary dd-roster-action-button" OnClick="@(OnChangeLocation)">
                        Change
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Size="Size.Small" Class="dd-btn-primary dd-roster-action-button"
                               OnClick="OnResetBuilder">
                        Reset
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Size="Size.Small" Class="dd-btn-primary dd-roster-action-button"
                               OnClick="OnExportTeam">
                        Export Team
                    </MudButton>
                </div>

                <div class="d-flex justify-space-between align-end mb-2 mt-4 pb-1">
                    <MudText Typo="Typo.subtitle1" Class="dd-text-heading">Available Heroes</MudText>
                    <MudText Typo="Typo.caption" Class="dd-text-muted-italic mr-4 pr-2">* Hold portrait to drag</MudText>
                </div>

                <div class="dd-roster-filter-row">
                    <MudSelect T="Skill.SkillEffect?" @bind-Value="_selectedEffectFilter" Placeholder="All Abilities" AnchorOrigin="Origin.BottomLeft" Class="dd-filter-select">
                        <MudSelectItem T="Skill.SkillEffect?" Value="@(null)">All Abilities</MudSelectItem>

                        @foreach (Skill.SkillEffect effect in Enum.GetValues<Skill.SkillEffect>())
                        {
                            if (effect != Skill.SkillEffect.None)
                            {
                                <MudSelectItem T="Skill.SkillEffect?" Value="@effect">@effect.ToString()</MudSelectItem>
                            }
                        }
                    </MudSelect>

                    <MudTextField @bind-Value="_searchString"
                                  Placeholder="Search..."
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  IconSize="Size.Small"
                                  DebounceInterval="250"
                                  Class="dd-input-text">
                    </MudTextField>
                </div>

                <div class="dd-roster-table-wrap">
                    <MudTable Items="@Roster"
                              Filter="_filterFunc"
                              Hover="true"
                              Dense="true"
                              Elevation="0"
                              Breakpoint="Breakpoint.None"
                              Class="dd-roster-table">

                    <HeaderContent>
                        <MudTh></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<Hero, object>(x => x.Name)" Class="dd-sort-label">Name</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<Hero, object>(x => x.Role)" Class="dd-sort-label">Role</MudTableSortLabel></MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>

                    <RowTemplate>
                        <MudTd DataLabel="Portrait">
                            <div @ondragstart="@(() => OnHeroDragStart.InvokeAsync(context))">

                                <div draggable="true"
                                     data-drag-image="@context.Sprite"
                                     ondragstart="setCustomDragImage(event, '@context.Sprite')"
                                     class="dd-drag-handle">

                                    <img src="@context.Sprite"
                                         class="drag-ghost-img dd-drag-ghost-img"
                                         width="170"
                                         height="334"
                                         alt="sprite of @context.Sprite" />

                                    <MudAvatar>
                                        <MudImage Src="@context.Portrait"></MudImage>
                                    </MudAvatar>
                                </div>
                            </div>
                        </MudTd>

                        <MudTd DataLabel="Name" Class="dd-roster-name-cell">
                            <div class="dd-roster-name-row">
                                <MudTooltip Text="@context.Name">
                                    <MudText Typo="Typo.body1" Class="dd-roster-name-text">
                                        <strong class="dd-hero-name-strong dd-roster-name-strong">@context.Name</strong>
                                    </MudText>
                                </MudTooltip>
                                @if (SelectedLocation.RecommendedHeroes != null && SelectedLocation.RecommendedHeroes.Contains(context))
                                {
                                    <MudTooltip Text="@($"Recommended hero for {SelectedLocation.Name}")">
                                        <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Primary" Size="Size.Small"></MudIcon>
                                    </MudTooltip>
                                }
                            </div>
                        </MudTd>

                        <MudTd DataLabel="Role" Class="dd-roster-role-cell">
                            <MudText Typo="Typo.caption" Class="dd-role-text dd-roster-role-text">@context.Role</MudText>
                        </MudTd>

                        <MudTd DataLabel="Action" Class="dd-roster-action-cell">
                            <MudMenu Icon="@Icons.Material.Filled.Add" Color="Color.Secondary"
                                     TransformOrigin="Origin.CenterLeft" AnchorOrigin="Origin.BottomRight"
                                     Dense="true"
                                     Class="dd-roster-action-menu">
                                <MudMenuItem @onclick="@(() => OnAddHero.InvokeAsync((context, 1)))">1</MudMenuItem>
                                <MudMenuItem @onclick="@(() => OnAddHero.InvokeAsync((context, 2)))">2</MudMenuItem>
                                <MudMenuItem @onclick="@(() => OnAddHero.InvokeAsync((context, 3)))">3</MudMenuItem>
                                <MudMenuItem @onclick="@(() => OnAddHero.InvokeAsync((context, 4)))">4</MudMenuItem>
                            </MudMenu>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
                </div>
            </MudItem>

@code {
    [Parameter, EditorRequired] public DungeonLocation SelectedLocation { get; set; } = null!;
    [Parameter, EditorRequired] public List<Hero> Roster { get; set; } = new();

    [Parameter] public EventCallback OnChangeLocation { get; set; }
    [Parameter] public EventCallback OnResetBuilder { get; set; }
    [Parameter] public EventCallback OnExportTeam { get; set; }

    [Parameter] public EventCallback<Hero> OnHeroDragStart { get; set; }
    [Parameter] public EventCallback OnDropToRoster { get; set; }
    [Parameter] public EventCallback<(Hero hero, int slot)> OnAddHero { get; set; }
    private string _searchString = "";
    private Skill.SkillEffect? _selectedEffectFilter = null;
    private Func<Hero, bool> _filterFunc = null!;

    protected override void OnInitialized()
    {
        _filterFunc = FilterHeroes;
    }

    private bool FilterHeroes(Hero hero)
    {
        if (_selectedEffectFilter.HasValue)
        {

            var hasDesiredSkill = hero.Skills.Any(s => (s.EffectsBitfield & _selectedEffectFilter.Value) != Skill.SkillEffect.None);
            if (!hasDesiredSkill)
            {
                return false;
            }
        }
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        if (hero.Role.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (hero.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;


        return false;
    }
}
