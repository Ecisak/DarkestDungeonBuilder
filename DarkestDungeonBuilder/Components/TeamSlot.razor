@using DarkestDungeonBuilder.Models
@inject IDialogService DialogService

@if (Hero == null)
{
    @* empty *@
    <MudPaper Class="pa-4 d-flex flex-column align-center justify-center dd-slot-empty"
              @ondragover:preventDefault="true"
              @ondrop="HandleDrop">
        <MudText Typo="Typo.h5" Class="dd-slot-rank-number">@SlotKey</MudText>
        <MudText Typo="Typo.body1" Class="dd-slot-empty-text">Empty</MudText>
    </MudPaper>
}
else
{
    @* Ooccupied *@
    <MudPaper Class="pa-4 d-flex flex-column align-center dd-slot-occupied"
              draggable="true"
              @ondragstart="HandleDragStart"
              @ondragover:preventDefault="true"
              @ondrop="HandleDrop">

        @* position circles *@
        <div class="d-flex gap-2 align-center mb-4 dd-slot-position-row">
            @{
                var scores = Hero.GetPreferredPositions();
            }
            @for (int i = 3; i >= 0; i--)
            {
                int currentScore = scores[i];
                int innerSize = currentScore == 0 ? 0 : 4 + (currentScore * 6);
                double opacity = currentScore == 0 ? 0.3 : 0.6 + (currentScore * 0.1);

                <div class="dd-position-circle">
                    <div class="dd-position-circle-inner" style="@($"--dd-position-size: {innerSize}px; --dd-position-opacity: {opacity.ToString(System.Globalization.CultureInfo.InvariantCulture)};")"></div>
                </div>
            }
        </div>

        @* hero info *@
        <div class="d-flex align-center gap-1">
            <MudText Typo="Typo.subtitle2" Class="dd-slot-rank-label">Rank @SlotKey</MudText>
            @if (HasIncompleteLoadout)
            {
                <MudTooltip Text="@LoadoutWarningText">
                    <MudIcon Icon="@Icons.Material.Filled.WarningAmber" Size="Size.Small" Style="color: #d0a44c;" />
                </MudTooltip>
            }
        </div>
        <div class="dd-slot-name-wrap">
            <MudText Typo="Typo.h6" Class="font-weight-bold dd-slot-hero-name" style="@($"--dd-hero-name-size: {Math.Min(1.25, 12.0 / Hero.Name.Length).ToString(System.Globalization.CultureInfo.InvariantCulture)}rem;")">@Hero.Name</MudText>
        </div>
        <div class="dd-slot-sprite-wrap">
            <MudImage Src="@Hero.Sprite" Class="dd-slot-sprite" />
        </div>

        <div class="d-flex flex-column align-center w-100">
            <div class="d-flex gap-2 justify-center my-3">
                @for (int i = 0; i < 2; i++)
                {
                    int slotIndex = i;
                    var equippedTrinket = Hero.EquippedTrinkets[slotIndex];

                    <MudPaper Width="54px" Height="54px"
                              Class="d-flex align-center justify-center border-dashed border-2 cursor-pointer dd-trinket-slot"
                              @onclick="@(() => OpenTrinketDialog(slotIndex))">

                        @if (equippedTrinket == null)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Add" Class="dd-trinket-add-icon" />
                        }
                        else
                        {
                            <MudTooltip Text="@($"{equippedTrinket.Name}: {equippedTrinket.Effects}")">
                                <MudImage Src="@equippedTrinket.TrinketImage" Width="48" Height="48" ObjectFit="ObjectFit.Contain" />
                            </MudTooltip>
                        }
                    </MudPaper>
                }
            </div>
            @* selected spells info *@
            <div class="d-flex flex-row justify-center gap-4 my-4 w-100">

                @* combat skills *@
                <div class="d-flex flex-wrap justify-center dd-skill-column">
                    @foreach (var skill in Hero.SelectedSkills.Where(s => s.Category == Skill.SkillCategory.Combat))
                    {
                        <MudTooltip>
                            <ChildContent>
                                <MudImage Src="@(skill.SkillImage)" Width="48" Height="48" Class="rounded ma-1" Alt="@skill.Name" />
                            </ChildContent>
                            <TooltipContent>
                                <div class="d-block">@skill.Name</div>
                                <div class="d-block">
                                    @for (int i = 4; i >= 1; i--)
                                    {
                                        <span>@(skill.CastablePositions.Contains(i) ? "🟡" : "⚫")</span>
                                    }
                                    @if (!skill.IsFriendly)
                                    {
                                        <MudText Class="d-inline dd-tooltip-separator"> | </MudText>
                                        @for (int i = 1; i <= 4; i++)
                                        {
                                            <span>@(skill.Targets.Contains(i) ? "🔴" : "⚫")</span>
                                        }
                                    }
                                </div>
                            </TooltipContent>
                        </MudTooltip>
                    }
                </div>

                @* line *@
                <MudDivider Vertical="true" FlexItem="true" />

                @* camping skills *@
                <div class="d-flex flex-wrap justify-center dd-skill-column">
                    @foreach (var skill in Hero.SelectedSkills.Where(s => s.Category == Skill.SkillCategory.Camping))
                    {
                        <MudTooltip>
                            <ChildContent>
                                <MudImage Src="@(skill.SkillImage)" Width="48" Height="48" Class="rounded ma-1" Alt="@skill.Name" />
                            </ChildContent>
                            <TooltipContent>
                                <div class="d-block">@skill.Name</div>
                            </TooltipContent>
                        </MudTooltip>
                    }
                </div>
            </div>

            @* buttons *@
            <div class="d-flex gap-2 mt-auto pt-4">
                <MudTooltip Text="Delete">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Variant="Variant.Filled" Class="dd-delete-button" Size="Size.Small" @onclick="HandleRemove" />
                </MudTooltip>
                <MudTooltip Text="Edit Loadout">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Variant="Variant.Filled" Class="dd-edit-button" Size="Size.Small" @onclick="HandleEdit" />
                </MudTooltip>
            </div>
        </div>

    </MudPaper>
}

@code {
    [Parameter] public Hero? Hero { get; set; }
    [Parameter] public int SlotKey { get; set; }

    [Parameter] public EventCallback<int> OnDrop { get; set; }
    [Parameter] public EventCallback<int> OnRemove { get; set; }
    [Parameter] public EventCallback<Hero> OnEdit { get; set; }
    [Parameter] public EventCallback OnLoadoutChanged { get; set; }

    [Parameter] public List<Trinket> AvailableTrinkets { get; set; } = new();

    [Parameter] public EventCallback<int> OnDragStart { get; set; }

    private int CombatSkillCount => Hero?.SelectedSkills.Count(s => s.Category == Skill.SkillCategory.Combat) ?? 0;
    private int CampingSkillCount => Hero?.SelectedSkills.Count(s => s.Category == Skill.SkillCategory.Camping) ?? 0;
    private bool HasIncompleteLoadout => Hero != null && (CombatSkillCount < 4 || CampingSkillCount < 4);
    private string LoadoutWarningText => $"Incomplete loadout: {CombatSkillCount}/4 combat skills, {CampingSkillCount}/4 camping skills.";

    private async Task HandleDragStart() => await OnDragStart.InvokeAsync(SlotKey);

    private async Task OpenTrinketDialog(int trinketSlotIndex)
    {
        var parameters = new DialogParameters<TrinketView>
        {
            { x => x.AllTrinkets, AvailableTrinkets },
            { x => x.CurrentHero, Hero }
        };

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };

        var dialog = await DialogService.ShowAsync<TrinketView>("Select Trinket", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: Trinket selectedTrinket })
        {
            Hero?.EquippedTrinkets[trinketSlotIndex] = selectedTrinket;
            await OnLoadoutChanged.InvokeAsync();
            StateHasChanged();

        }
    }

    private async Task HandleDrop() => await OnDrop.InvokeAsync(SlotKey);
    private async Task HandleRemove() => await OnRemove.InvokeAsync(SlotKey);

    private async Task HandleEdit()
    {
        if (Hero != null)
        {
            await OnEdit.InvokeAsync(Hero);
        }
    }
}
