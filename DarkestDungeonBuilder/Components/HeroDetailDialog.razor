@using System.Web
@using DarkestDungeonBuilder.Models

<MudDialog>
    <TitleContent>Setup @Hero?.Name</TitleContent>
    
    <DialogContent>
        
        <MudText Typo="Typo.h6">@Hero?.Name</MudText>
        <MudImage Src="@Hero?.Portrait"/>

        @if (@Hero?.Skills != null)
        {
            <MudText>Choose 4 Combat Skills</MudText>

            foreach (var skill in Hero.Skills.Where(s => s.Category == Skill.SkillCategory.Combat))
            {
                bool isSelected = Hero.SelectedSkills.Any(s => s.Name == skill.Name);
                string imgStyle = isSelected 
                    ? "filter: none; opacity: 1; transition: filter 0.3s, opacity 0.3s;" 
                    : "filter: grayscale(100%); opacity: 0.4; transition: filter 0.3s, opacity 0.3s;";
                <MudImage 
                    Src="@(skill.SkillImage)"
                    Width="48" 
                    Height="48" 
                    Class="rounded ma-1" 
                    Style="@imgStyle"
                    @onclick="@(() => OnSkillToggled(skill, !isSelected))"
                    Alt="@skill.Name" />
                <div class="d-flex gap-1">
                    @for (int i = 1; i <= 4; i++)
                    {
                        if (skill.CastablePositions.Contains(i))
                        {
                            <span>🟡</span>
                        }
                        else
                        {
                            <span>⚫</span>
                        }
                    }
                    |
                    @for (int i = 1; i <= 4; i++)
                    {
                        if (skill.Targets.Contains(i))
                        {
                            <span>🔴</span>
                        } 
                        else
                        {
                            <span>⚫</span>
                        }
                    }
                </div>

            }

            <MudText>Choose 4 Camping Skills</MudText>
            foreach (var skill in Hero.Skills.Where(s => s.Category == Skill.SkillCategory.Camping))
            {
                bool isSelected = Hero.SelectedSkills.Any(s => s.Name == skill.Name);
                string imgStyle = isSelected 
                    ? "filter: none; opacity: 1; transition: filter 0.3s, opacity 0.3s;" 
                    : "filter: grayscale(100%); opacity: 0.4; transition: filter 0.3s, opacity 0.3s;";
                <MudImage 
                    Src="@(skill.SkillImage)"
                    Width="48" 
                    Height="48" 
                    Class="rounded ma-1" 
                    Style="@imgStyle"
                    @onclick="@(() => OnSkillToggled(skill, !isSelected))"
                    Alt="@skill.Name" />
            }

        }
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Close">Save and Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance? MudDialog { get; set; }
    [Parameter]
    public Hero? Hero { get; set; }

    private void Close() {
        MudDialog?.Close(DialogResult.Ok(true));
    }
    private async Task OnSkillToggled(Skill skill, bool isChecked)
    {
        if (isChecked )
        {
            if (Hero?.SelectedSkills.Count(s => s.Category == skill.Category) < 4)
            {
                Hero?.SelectedSkills.Add(skill);
                
            }
        }

        else
        {
            Hero?.SelectedSkills.RemoveAll(s => s.Name == skill.Name);
        }
    }

    private bool LockSkills(Skill skill)
    {
        var count = Hero?.SelectedSkills.Count(s => s.Category == skill.Category);
        var isAlreadySelected = Hero.SelectedSkills.Any(s => s.Name == skill.Name);
        return (count >= 4) && (!isAlreadySelected);
    }
}

