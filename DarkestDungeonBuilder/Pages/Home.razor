@page "/"
@using DarkestDungeonBuilder.Components
@using DarkestDungeonBuilder.Models
@using DarkestDungeonBuilder.Services
@inject HeroDatabase Db
@inject IDialogService DialogService

<PageTitle>Darkest Dungeon Builder</PageTitle>

<MudText Typo="Typo.h3">Darkest Dungeon Builder</MudText>



@code {


    private List<Hero> _roster = null!;

    protected override void OnInitialized()
    {
        _roster = Db.GetInitialRoster();

    }

    private readonly Team _currentTeam = new Team();

    private void AddHero(Hero hero)
    {
        foreach (var slot in _currentTeam.Slots.ToList())
        {
            if (slot.Value != null) continue;
            var cloned = hero.Clone();
            _currentTeam.Slots[slot.Key] = cloned;
            break;
        }
    }

    private void RemoveHero(Hero hero)
    {
        foreach (var slot in _currentTeam.Slots)
        {
            if (slot.Value == hero)
            {
                _currentTeam.Slots[slot.Key] = null;
            }
        }
    }

    private Task OpenDialogAsync(Hero hero)
    {
        var parameters = new DialogParameters<HeroDetailDialog> { { x => x.Hero, hero } };
        
        return DialogService.ShowAsync<HeroDetailDialog>("Simple Dialog", parameters);
    }
    

    

}

<MudGrid>
    <!-- left panel: list of heroes -->
    <MudItem xs="3">
        <MudPaper Class="pa-4" Style="height: 100%">
            <MudText Typo="Typo.h6">Hero Roster</MudText>
            <MudDataGrid Items="@_roster" Hover="true" Dense="true">
                <Columns>
                    <PropertyColumn Property="x => x.Name" Title="Name" />
                    <PropertyColumn Property="x => x.Role" Title="Role" />
                    <TemplateColumn CellClass="d-flex justify-end">
                        <CellTemplate>
                            <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Filled.Add" Color="Color.Primary" @onclick=@(() => AddHero(context.Item))/>
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
            </MudDataGrid>
            </MudPaper>
    </MudItem>
    
    <!-- center panel, team composition -->
    <MudItem xs="6">
        <MudGrid>
            @foreach (var hero in _currentTeam.Slots)
            {
                <MudItem xs="3">
                    <MudPaper Class="pa-4">
                        <MudText Typo="Typo.h6">@hero.Key</MudText>
                        @if (hero.Value == null)
                        {
                            <MudText Typo="Typo.h6">Empty</MudText>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" @onclick="@(() => OpenDialogAsync(hero.Value))">@hero.Value.Name</MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Error" @onclick="@(() => RemoveHero(hero.Value))">DELETE</MudButton>
                        }
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    </MudItem>
    
    <!-- right panel: stats and warnings -->
    <MudItem xs="3">
        <MudPaper Class="pa-4">Here will be radar graph and warnings</MudPaper>
    </MudItem>
</MudGrid>